APP_NAME="APK-TV OTT Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Cambiar DB_CONNECTION a 'pgsql' para PostgreSQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apktv_db
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache ────────────────────────────────────────────────────────────────────
# Para producción se recomienda 'redis' en lugar de 'database'
CACHE_STORE=database
# CACHE_STORE=redis

# ─── Sesiones ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─── Redis (Opcional, recomendado para producción) ────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Queue ────────────────────────────────────────────────────────────────────
# Para parseo de listas M3U grandes en background, usar 'redis' o 'database'
QUEUE_CONNECTION=database

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@apktv.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=debug

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Activar log de seguridad (alertas de IPs sospechosas, intentos fallidos)
SECURITY_LOG=true
BCRYPT_ROUNDS=12

# ─── GeoIP (stevebauman/location) ────────────────────────────────────────────
# Driver por defecto usa IpApi (gratuito).
# Para producción de alto volumen, cambiar a MaxMind GeoIP2.
# LOCATION_DRIVER=maxmind_database
# MAXMIND_DATABASE_PATH=/path/to/GeoLite2-City.mmdb

# ─── Notas de Producción ──────────────────────────────────────────────────────
# 1. Cambiar APP_ENV=production y APP_DEBUG=false
# 2. Generar APP_KEY con: php artisan key:generate
# 3. Configurar DB_* con credenciales reales del servidor
# 4. Usar CACHE_STORE=redis para mejor rendimiento
# 5. Nunca exponer este archivo en repositorios públicos
# 6. Ejecutar: php artisan migrate --force (en producción)
# 7. Ejecutar: php artisan db:seed --class=AdminSeeder
